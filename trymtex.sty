\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{trymtex}[2026/04/09 v0.4 General-purpose document setup package]

% =============================================================================
% Dependencies
% =============================================================================
\RequirePackage{iftex}
\RequirePackage{xcolor}
\RequirePackage{kvoptions}
\RequirePackage{etoolbox}

% =============================================================================
% Options
% =============================================================================
\SetupKeyvalOptions{family=trymtex,prefix=trymtex@}

% --- language ----------------------------------------------------------------
\DeclareStringOption[]{mainlanguage}
\DeclareStringOption[]{languages}
\DeclareBoolOption[false]{babel}

% --- typography ---------------------------------------------------------------
\DeclareStringOption[libertinus]{fontset}
\DeclareBoolOption[true]{microtype}

% --- feature modules ----------------------------------------------------------
\DeclareBoolOption[false]{biblatex}
\DeclareStringOption[biber]{bibbackend}
\DeclareBoolOption[true]{minted}
\DeclareBoolOption[true]{glossaries}
\DeclareBoolOption[true]{theorems}
\DeclareBoolOption[true]{algorithms}
\DeclareBoolOption[true]{plots}
\DeclareBoolOption[true]{pagegeometry}
\DeclareBoolOption[true]{fancyhdr}
\DeclareBoolOption[true]{toc}

% --- fontset aliases ----------------------------------------------------------
\DeclareVoidOption{libertinus}{\renewcommand\trymtex@fontset{libertinus}}
\DeclareVoidOption{pagella}{\renewcommand\trymtex@fontset{pagella}}
\DeclareVoidOption{ibmplex}{\renewcommand\trymtex@fontset{ibmplex}}
\DeclareVoidOption{fira}{\renewcommand\trymtex@fontset{fira}}
\DeclareVoidOption{none}{\renewcommand\trymtex@fontset{none}}

\ProcessKeyvalOptions*

% =============================================================================
% Internal helpers
% =============================================================================
\newcommand{\trymtex@warning}[1]{%
  \PackageWarningNoLine{trymtex}{#1}%
}

\newcommand{\trymtex@error}[2]{%
  \PackageError{trymtex}{#1}{#2}%
}

\newcommand{\trymtex@ifbool}[2]{%
  \csname iftrymtex@#1\endcsname
  #2%
  \fi
}

\newcommand{\trymtex@use@setup}[2]{%
  \ifcsdef{trymtex@setup@#1@#2}
  {\csname trymtex@setup@#1@#2\endcsname}
  {%
    \trymtex@warning{Unknown #1 setup '#2'. Falling back to 'libertinus'}%
    \csname trymtex@setup@#1@libertinus\endcsname
  }%
}

\newcommand{\trymtex@load@babel}{%
  \edef\trymtex@babelopts{}%
  \ifdefempty{\trymtex@mainlanguage}
  {}
  {\edef\trymtex@babelopts{main=\trymtex@mainlanguage}}%
  \ifdefempty{\trymtex@languages}
  {}
  {%
    \ifdefempty{\trymtex@babelopts}
    {\edef\trymtex@babelopts{\trymtex@languages}}
    {\edef\trymtex@babelopts{\trymtex@babelopts,\trymtex@languages}}%
  }%
  \ifdefempty{\trymtex@babelopts}
  {\RequirePackage{babel}}
  {\expandafter\RequirePackage\expandafter[\trymtex@babelopts]{babel}}%
}

% =============================================================================
% Core module
% =============================================================================
\newcommand{\trymtex@load@core}{%
  \iftrymtex@microtype
    \RequirePackage[final]{microtype}%
  \fi

  \ifPDFTeX
    \RequirePackage[T1]{fontenc}%
    \RequirePackage[utf8]{inputenc}%
  \fi

  \RequirePackage{anyfontsize}

  \iftrymtex@babel
    \trymtex@load@babel
  \fi

  \RequirePackage{ragged2e}
  \RequirePackage{enumitem}
  \RequirePackage{suffix}
  \iftrymtex@minted
    \RequirePackage{fvextra}
  \fi
  \RequirePackage[autostyle]{csquotes}

  \RequirePackage{amsmath}
  \RequirePackage{mathtools}
  \RequirePackage{amsthm}

  \ifPDFTeX
    \RequirePackage{amssymb}
    \RequirePackage{bm}
    \trymtex@use@setup{pdftex}{\trymtex@fontset}
  \else
    \RequirePackage{fontspec}
    \RequirePackage[
      math-style=ISO,
      warnings-off={mathtools-colon,mathtools-overbracket}
    ]{unicode-math}
    \trymtex@use@setup{unicode}{\trymtex@fontset}
    \providecommand{\bm}[1]{\symbf{##1}}
  \fi

  \RequirePackage{booktabs}
  \RequirePackage{tabularx}
  \RequirePackage{array}
  \RequirePackage{colortbl}
  \RequirePackage{multirow}
  \RequirePackage{siunitx}
  \RequirePackage{float}
  \RequirePackage{subcaption}

  \RequirePackage[most]{tcolorbox}

  \RequirePackage[colorlinks]{hyperref}
  \RequirePackage{bookmark}
  \hypersetup{
    colorlinks = true,
    linkcolor  = blue,
    filecolor  = magenta,
    urlcolor   = cyan
  }

  \setlength{\parindent}{0pt}
  \setlength{\parskip}{0.5em}
}

% =============================================================================
% Optional modules
% =============================================================================
\newcommand{\trymtex@load@biblatex}{%
  \RequirePackage[backend=\trymtex@bibbackend]{biblatex}%
}

\newcommand{\trymtex@load@layout}{%
  \iftrymtex@pagegeometry
    \RequirePackage[
      margin=2.5cm,
      headheight=15pt,
      includeheadfoot
    ]{geometry}%
  \fi

  \iftrymtex@fancyhdr
    \RequirePackage{fancyhdr}
    \pagestyle{fancy}
    \fancyhf{}
    \fancyhead[L]{\leftmark}
    \fancyhead[R]{\thepage}
    \fancyfoot[C]{\thepage}
    \renewcommand{\headrulewidth}{0.4pt}
    \renewcommand{\footrulewidth}{0.4pt}
  \fi

  \iftrymtex@toc
    \RequirePackage{tocloft}
    \renewcommand{\cftsubsubsecfont}{\normalfont}
    \renewcommand{\cftsubsubsecleader}{\cftdotfill{\cftdotsep}}
    \renewcommand{\cftsubsubsecafterpnum}{\hspace*{2em}}
  \fi
}

\newcommand{\trymtex@load@glossaries}{%
  \RequirePackage[
    acronym,
    symbols,
    nogroupskip,
    hyperfirst=true
  ]{glossaries-extra}
  \setglossarystyle{listhypergroup}
}

\newcommand{\trymtex@load@minted}{%
  \RequirePackage{minted}
}

\newcommand{\trymtex@load@algorithms}{%
  \RequirePackage[lined,boxed,commentsnumbered,linesnumbered]{algorithm2e}
  \SetAlgorithmName{Algorithm}{Algorithm}{List of Algorithms}
  \SetAlCapFnt{\color{alg-color}\bfseries}
  \SetAlCapNameSty{TitleBox}
  \DontPrintSemicolon
  \SetKwProg{Fn}{Function}{:}{}
  \SetKwFunction{Error}{error}
  \SetKwInput{KwInput}{Input}
  \SetKwInput{KwOutput}{Output}
}

\newcommand{\trymtex@load@plots}{%
  \RequirePackage{pgfplots}
  \pgfplotsset{compat=1.18}
  \RequirePackage{forest}
}

% =============================================================================
% Font setups
% =============================================================================
\newcommand{\trymtex@setup@pdftex@libertinus}{%
  \RequirePackage{libertinus}
}

\newcommand{\trymtex@setup@pdftex@pagella}{%
  \RequirePackage{newpxtext}
  \RequirePackage{newpxmath}
}

\newcommand{\trymtex@setup@pdftex@ibmplex}{%
  \RequirePackage{libertinus}
  \trymtex@warning{IBM Plex is not supported under pdfTeX; using libertinus instead}
}

\newcommand{\trymtex@setup@pdftex@fira}{%
  \RequirePackage{libertinus}
  \trymtex@warning{Fira is not supported under pdfTeX; using libertinus instead}
}

\newcommand{\trymtex@setup@pdftex@none}{}

\newcommand{\trymtex@setup@unicode@libertinus}{%
  \setmainfont{Libertinus Serif}
  \setsansfont{Libertinus Sans}
  \setmonofont{Libertinus Mono}
  \setmathfont{Libertinus Math}
}

\newcommand{\trymtex@setup@unicode@pagella}{%
  \setmainfont{TeX Gyre Pagella}
  \setsansfont{TeX Gyre Heros}
  \setmonofont{Inconsolata}
  \setmathfont{TeX Gyre Pagella Math}
}

\newcommand{\trymtex@setup@unicode@ibmplex}{%
  \setmainfont{IBM Plex Serif}
  \setsansfont{IBM Plex Sans}
  \setmonofont{IBM Plex Mono}
  \setmathfont{STIX Two Math}
}

\newcommand{\trymtex@setup@unicode@fira}{%
  \setmainfont{Fira Sans}[
    BoldFont   = {Fira Sans Bold},
    ItalicFont = {Fira Sans Italic}
  ]
  \setsansfont{IBM Plex Sans Condensed}[Scale=0.95]
  \setmonofont{Fira Code}[
    Scale=0.9,
    Contextuals=Alternate
  ]
  \setmathfont{Fira Math}
  \setmathfont{STIX Two Math}[
    range={
        \mathscr,\mathbb,\mathfrak,\mathcal,
        \setminus,\Re,\Im,\triangleright,\top,
        \ddots,\vdots,\star,\bigcup
      },
    Scale=MatchUppercase
  ]
}

\newcommand{\trymtex@setup@unicode@none}{}

% =============================================================================
% Load selected modules
% =============================================================================
\trymtex@load@core

\iftrymtex@biblatex
  \trymtex@load@biblatex
\fi

\trymtex@load@layout

\iftrymtex@glossaries
