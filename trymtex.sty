\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{trymtex}[2026/04/08 v0.2 General-purpose document setup package]
\RequirePackage{iftex}
\RequirePackage{xcolor}
\RequirePackage{kvoptions}
\RequirePackage{etoolbox}

\SetupKeyvalOptions{family=trymtex,prefix=trymtex@}

% --------------------------------------------------------------------------
% Options
% --------------------------------------------------------------------------
\DeclareStringOption[]{mainlanguage}
\DeclareStringOption[]{languages}
\DeclareBoolOption[false]{babel}
\DeclareBoolOption[true]{microtype}
\DeclareBoolOption[true]{minted}
\DeclareBoolOption[true]{glossaries}
\DeclareBoolOption[true]{theorems}
\DeclareBoolOption[true]{algorithms}
\DeclareBoolOption[true]{plots}
\DeclareBoolOption[true]{pagegeometry}
\DeclareBoolOption[true]{fancyhdr}
\DeclareBoolOption[true]{toc}
\DeclareStringOption[pagella]{fontset}
\DeclareVoidOption{pagella}{\renewcommand\trymtex@fontset{pagella}}
\DeclareVoidOption{ibmplex}{\renewcommand\trymtex@fontset{ibmplex}}
\DeclareVoidOption{fira}{\renewcommand\trymtex@fontset{fira}}
\DeclareVoidOption{none}{\renewcommand\trymtex@fontset{none}}
\ProcessKeyvalOptions*

% --------------------------------------------------------------------------
% Core language/typography
% --------------------------------------------------------------------------
\iftrymtex@microtype
  \RequirePackage[final]{microtype}
\fi

\ifPDFTeX
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
\fi

\iftrymtex@babel
  \edef\trymtex@babelopts{}
  \ifdefempty{\trymtex@mainlanguage}{}{%
    \edef\trymtex@babelopts{main=\trymtex@mainlanguage}%
  }
  \ifdefempty{\trymtex@languages}{}{%
    \ifdefempty{\trymtex@babelopts}
    {\edef\trymtex@babelopts{\trymtex@languages}}
    {\edef\trymtex@babelopts{\trymtex@babelopts,\trymtex@languages}}%
  }
  \expandafter\RequirePackage\expandafter[\trymtex@babelopts]{babel}
\fi

\RequirePackage{ragged2e}
\RequirePackage{enumitem}
\RequirePackage{suffix}
\RequirePackage[autostyle]{csquotes}
\RequirePackage[backend=biber]{biblatex}
% --------------------------------------------------------------------------
% Fonts and math (engine-dependent)
% --------------------------------------------------------------------------
\RequirePackage{amsmath}
\RequirePackage{mathtools}
\RequirePackage{amsthm}

\providecommand{\trymtex@setup@pdftex@pagella}{%
  \RequirePackage{newpxtext}
  \RequirePackage{newpxmath}}
\providecommand{\trymtex@setup@pdftex@ibmplex}{%
  \RequirePackage{newpxtext}
  \RequirePackage{newpxmath}%
  \PackageWarningNoLine{trymtex}{IBM Plex is not supported under pdfTeX; using newpxtext/newpxmath instead}}
\providecommand{\trymtex@setup@pdftex@fira}{%
  \RequirePackage{newpxtext}
  \RequirePackage{newpxmath}%
  \PackageWarningNoLine{trymtex}{Fira OpenType setup is not supported under pdfTeX; using newpxtext/newpxmath instead}}
\providecommand{\trymtex@setup@pdftex@none}{}

\providecommand{\trymtex@setup@unicode@pagella}{%
  \setmainfont{TeX Gyre Pagella}
  \setsansfont{TeX Gyre Heros}
  \setmonofont{Inconsolata}
  \setmathfont{TeX Gyre Pagella Math}}
\providecommand{\trymtex@setup@unicode@ibmplex}{%
  \setmainfont{IBM Plex Serif}
  \setsansfont{IBM Plex Sans}
  \setmonofont{IBM Plex Mono}
  \setmathfont{STIX Two Math}}
\providecommand{\trymtex@setup@unicode@fira}{%
  \setmainfont{Fira Sans}[
    Scale=1.0,
    BoldFont={Fira Sans Bold},
    ItalicFont={Fira Sans Italic}
  ]
  \setsansfont{IBM Plex Sans Condensed}[Scale=0.95]
  \setmonofont{Fira Code}[
    Scale=0.9,
    Contextuals=Alternate
  ]
  \setmathfont{Fira Math}
  \setmathfont{STIX Two Math}[
    range={
        \mathscr,\mathbb,\mathfrak,\mathcal,
        \setminus,\Re,\Im,\triangleright,\top,
        \ddots,\vdots,\star,\bigcup
      },
    Scale=MatchUppercase
  ]}

\ifPDFTeX
  \RequirePackage{amssymb}
  \RequirePackage{bm}
  \csname trymtex@setup@pdftex@\trymtex@fontset\endcsname
\else
  \RequirePackage{fontspec}
  \RequirePackage[
    math-style=ISO,
    warnings-off={mathtools-colon,mathtools-overbracket}
  ]{unicode-math}
  \csname trymtex@setup@unicode@\trymtex@fontset\endcsname
  \providecommand{\bm}[1]{\symbf{#1}}
\fi

% --------------------------------------------------------------------------
% Tables, figures, floats, code
% --------------------------------------------------------------------------
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{colortbl}
\RequirePackage{multirow}
\RequirePackage{siunitx}
\RequirePackage{float}
\RequirePackage{subcaption}
\iftrymtex@minted
  \RequirePackage{minted}
\fi

% --------------------------------------------------------------------------
% Layout and PDF structure
% --------------------------------------------------------------------------
\RequirePackage[most]{tcolorbox}
\iftrymtex@pagegeometry
  \RequirePackage[headheight=15pt,margin=2.5cm,includeheadfoot]{geometry}
\fi
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}

\iftrymtex@fancyhdr
  \RequirePackage{fancyhdr}
  \pagestyle{fancy}
  \fancyhf{}
  \fancyhead[L]{\leftmark}
  \fancyhead[R]{\thepage}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0.4pt}
  \renewcommand{\footrulewidth}{0.4pt}
\fi

\iftrymtex@toc
  \RequirePackage{tocloft}
  \renewcommand{\cftsubsubsecfont}{\normalfont}
  \renewcommand{\cftsubsubsecleader}{\cftdotfill{\cftdotsep}}
  \renewcommand{\cftsubsubsecafterpnum}{\hspace*{2em}}
\fi

\RequirePackage[colorlinks]{hyperref}
\RequirePackage{bookmark}
\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  filecolor=magenta,
  urlcolor=cyan
}

\iftrymtex@glossaries
  \RequirePackage[acronym,symbols,nogroupskip,hyperfirst=true]{glossaries-extra}
  \setglossarystyle{listhypergroup}
\fi

