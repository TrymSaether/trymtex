\NeedsTeXFormat{LaTeX2e}[2020-10-01]
\ProvidesPackage{trymtex}[2026/04/08 v0.1 Modern LuaLaTeX setup package]

% --------------------------------------------------------------------------
% Package policy
% --------------------------------------------------------------------------
% trymtex is a LuaLaTeX-oriented package. It intentionally configures fonts,
% theorem environments, page layout, and a set of utility packages commonly
% used in mathematical notes and reports.

\RequirePackage{iftex}
\ifLuaTeX\else
  \PackageError{trymtex}
    {This package requires LuaLaTeX}
    {Compile your document with lualatex.}
\fi

\RequirePackage{kvoptions}
\SetupKeyvalOptions{
  family=trymtex,
  prefix=trymtex@
}

% Font family options
\DeclareBoolOption[true]{pagella}
\DeclareBoolOption[false]{ibmplex}
\DeclareBoolOption[false]{fira}

% Feature toggles
\DeclareBoolOption[true]{theorems}
\DeclareBoolOption[true]{algorithms}
\DeclareBoolOption[true]{minted}
\DeclareBoolOption[true]{glossaries}
\DeclareBoolOption[true]{plots}
\DeclareBoolOption[true]{layout}
\DeclareBoolOption[true]{headers}
\DeclareBoolOption[true]{hyperrefsetup}

% Language options
\DeclareStringOption[english]{mainlanguage}
\DeclareStringOption[norsk,english]{languages}

\ProcessKeyvalOptions*

% Normalize mutually exclusive font options
\newcount\trymtex@fontcount
\trymtex@fontcount=0\relax
\iftrymtex@pagella \advance\trymtex@fontcount by 1\relax\fi
\iftrymtex@ibmplex \advance\trymtex@fontcount by 1\relax\fi
\iftrymtex@fira \advance\trymtex@fontcount by 1\relax\fi
\ifnum\trymtex@fontcount>1\relax
  \PackageError{trymtex}
    {Choose only one font option among pagella, ibmplex, and fira}
    {Pass exactly one of these options, or accept the default pagella option.}
\fi
\ifnum\trymtex@fontcount=0\relax
  \trymtex@pagellatrue
\fi

% --------------------------------------------------------------------------
% Core packages
% --------------------------------------------------------------------------
\RequirePackage{fontspec}
\RequirePackage[final]{microtype}
\RequirePackage[\trymtex@languages,main=\trymtex@mainlanguage]{babel}
\RequirePackage{xcolor}
\RequirePackage{ragged2e}
\RequirePackage{enumitem}
\RequirePackage{suffix}
\RequirePackage[autostyle, english=american]{csquotes}
\RequirePackage[backend=biber]{biblatex}

% Tables, figures, code
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{colortbl}
\RequirePackage{multirow}
\RequirePackage{siunitx}
\RequirePackage{float}
\RequirePackage{subcaption}
\iftrymtex@minted
  \RequirePackage{minted}
\fi

% Math
\RequirePackage{amsmath}
\RequirePackage{mathtools}
\RequirePackage[
  math-style=ISO,
  warnings-off={mathtools-colon,mathtools-overbracket}
]{unicode-math}
\RequirePackage{amsfonts}
\RequirePackage{amsthm}

% Boxes and layout
\RequirePackage[most]{tcolorbox}
\iftrymtex@layout
  \RequirePackage[
    headheight=15pt,
    margin=2.5cm,
    includeheadfoot
  ]{geometry}
  \AtBeginDocument{%
    \setlength{\parindent}{0pt}%
    \setlength{\parskip}{0.5em}%
  }
\fi

\iftrymtex@headers
  \RequirePackage{fancyhdr}
\fi

\RequirePackage{tocloft}

\RequirePackage[colorlinks]{hyperref}
\RequirePackage{bookmark}

\iftrymtex@glossaries
  \RequirePackage[acronym,symbols,nogroupskip,hyperfirst=true]{glossaries-extra}
\fi

\RequirePackage{etoolbox}
\RequirePackage{xparse}

\iftrymtex@plots
  \RequirePackage{pgfplots}
  \pgfplotsset{compat=1.18}
  \RequirePackage{forest}
\fi
\RequirePackage{optidef}
\usetikzlibrary{
  arrows.meta,
  backgrounds,
  positioning,
  calc,
  decorations.pathreplacing,
  3d
}

\iftrymtex@algorithms
  \RequirePackage[lined,boxed,commentsnumbered,linesnumbered]{algorithm2e}
\fi

% --------------------------------------------------------------------------
% Fonts
% --------------------------------------------------------------------------
\defaultfontfeatures{Ligatures=TeX,Scale=MatchLowercase}

\iftrymtex@pagella
  \setmainfont{TeX Gyre Pagella}
  \setsansfont{TeX Gyre Heros}
  \setmonofont{Inconsolata}
  \setmathfont{TeX Gyre Pagella Math}
\fi

\iftrymtex@ibmplex
  \setmainfont{IBM Plex Serif}
  \setsansfont{IBM Plex Sans}
  \setmonofont{IBM Plex Mono}
  \setmathfont{STIX Two Math}
\fi

\iftrymtex@fira
  \setmainfont{Fira Sans Extra Condensed}
  \setsansfont{Fira Sans}
  \setmonofont{Fira Code}
  \setmathfont{Fira Math}[Scale=MatchLowercase]
\fi

% --------------------------------------------------------------------------
% Hyperref and glossary defaults
% --------------------------------------------------------------------------
\iftrymtex@hyperrefsetup
  \hypersetup{
    colorlinks=true,
    linkcolor=blue,
    filecolor=magenta,
    urlcolor=cyan
  }
\fi

\iftrymtex@glossaries
  \setglossarystyle{listhypergroup}
\fi

% --------------------------------------------------------------------------
% Header/footer and ToC defaults
% --------------------------------------------------------------------------
\iftrymtex@headers
  \pagestyle{fancy}
  \fancyhf{}
  \fancyhead[L]{\leftmark}
  \fancyhead[R]{\thepage}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0.4pt}
  \renewcommand{\footrulewidth}{0.4pt}
\fi

\renewcommand{\cftsubsubsecfont}{\normalfont}
\renewcommand{\cftsubsubsecleader}{\cftdotfill{\cftdotsep}}
\renewcommand{\cftsubsubsecafterpnum}{\hspace*{2em}}

% --------------------------------------------------------------------------
% Utility commands
% --------------------------------------------------------------------------
\newcommand{\ep}{\varepsilon}
\newcommand{\vp}{\varphi}
\newcommand{\cond}{\operatorname{cond}}
\newcommand{\bm}[1]{\symbf{#1}}
\newcommand{\bmat}[1]{\begin{bmatrix}#1\end{bmatrix}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\C}{\mathbb{C}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\Ccal}{\mathcal{C}}
\newcommand{\Hcal}{\mathcal{H}}
\newcommand{\Lcal}{\mathcal{L}}
\newcommand{\Lrm}{\mathrm{L}}
\newcommand{\Mcal}{\mathcal{M}}
\newcommand{\Pcal}{\mathcal{P}}
\newcommand{\F}{\mathcal{F}}
\newcommand{\I}{\mathcal{I}}
\newcommand{\D}{\mathcal{D}}
\newcommand{\spann}{\operatorname{span}}

\NewDocumentCommand{\dd}{ O{} m }{%
  \frac{d#1}{d{#2}}%
}
\NewDocumentCommand{\ddn}{ O{} m m }{%
  \frac{d^{#2}#1}{d{#3}^{#2}}%
}

\DeclarePairedDelimiter{\inner}{\langle}{\rangle}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}

\newcommand{\problem}[2]{%
  \par\noindent\large\textbf{Problem #1}\hfill\normalsize\textit{#2}\par
}
\newcommand{\subproblem}[1]{%
  \textbf{(#1)}%
}

